<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ridhi Thakker | Salesforce Engineer & Data Scientist</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --cream: #FAF7F2;
      --cream-dark: #F0EBE1;
      --ink: #1A1208;
      --ink-soft: #4A3F30;
      --ink-muted: #8C7B65;
      --accent: #C85A2A;
      --accent-light: #F5DDD2;
      --accent2: #2A6B8C;
      --accent2-light: #D0E8F5;
      --green: #2A7A4A;
      --green-light: #D0EDD8;
      --gold: #9A6F00;
      --gold-light: #F5EAC0;
      --border: #DDD5C8;
      --shadow: rgba(26,18,8,0.07);
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'DM Mono', monospace;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); background: var(--cream); color: var(--ink); line-height: 1.6; overflow-x: hidden; }

    /* NAVBAR */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(250,247,242,0.93);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      padding: 0 5vw;
      display: flex; align-items: center; justify-content: space-between;
      height: 62px;
    }
    .nav-logo { font-family: var(--font-display); font-size: 1.1rem; color: var(--ink); }
    .nav-links { display: flex; gap: 28px; list-style: none; align-items: center; }
    .nav-links a {
      font-size: 0.82rem; font-weight: 500; color: var(--ink-soft);
      text-decoration: none; letter-spacing: 0.05em; text-transform: uppercase;
      transition: color 0.2s; position: relative;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 1.5px; background: var(--accent); transition: width 0.25s;
    }
    .nav-links a:hover { color: var(--accent); }
    .nav-links a:hover::after { width: 100%; }
    .nav-cta {
      background: var(--ink) !important; color: var(--cream) !important;
      padding: 7px 18px; border-radius: 4px;
    }
    .nav-cta:hover { background: var(--accent) !important; }
    .nav-cta::after { display: none !important; }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; }
    .hamburger span { width: 24px; height: 1.5px; background: var(--ink); display: block; }

    /* HERO */
    .hero {
      min-height: 91vh; display: flex; align-items: center;
      padding: 80px 5vw 80px; position: relative; overflow: hidden;
    }
    .hero-blob {
      position: absolute; border-radius: 50%; z-index: 0; pointer-events: none;
    }
    .hero-blob.b1 { width: 520px; height: 520px; top: -160px; right: -80px; background: var(--accent-light); opacity: 0.6; }
    .hero-blob.b2 { width: 260px; height: 260px; bottom: 40px; left: 8%; background: var(--accent2-light); opacity: 0.5; }
    .hero-content { position: relative; z-index: 1; max-width: 700px; }
    .eyebrow {
      font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent);
      letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 22px;
      display: flex; align-items: center; gap: 12px;
    }
    .eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--accent); }
    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(3.2rem, 7.5vw, 5.8rem);
      line-height: 1.03; color: var(--ink); margin-bottom: 8px;
    }
    .hero h1 em { font-style: italic; color: var(--accent); }
    .hero-tagline { font-size: 1.1rem; color: var(--ink-soft); margin: 22px 0 34px; max-width: 540px; line-height: 1.75; }
    .tags { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 40px; }
    .tag {
      font-family: var(--font-mono); font-size: 0.73rem;
      padding: 5px 14px; border-radius: 20px; border: 1px solid; letter-spacing: 0.04em;
    }
    .tag-o { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }
    .tag-b { background: var(--accent2-light); border-color: var(--accent2); color: var(--accent2); }
    .tag-g { background: var(--green-light); border-color: var(--green); color: var(--green); }
    .tag-d { background: var(--gold-light); border-color: var(--gold); color: var(--gold); }
    .actions { display: flex; gap: 14px; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 13px 26px; border-radius: 4px;
      font-family: var(--font-body); font-size: 0.88rem; font-weight: 500;
      text-decoration: none; border: none; cursor: pointer; transition: all 0.2s; letter-spacing: 0.02em;
    }
    .btn-p { background: var(--ink); color: var(--cream); }
    .btn-p:hover { background: var(--accent); transform: translateY(-1px); }
    .btn-o { background: transparent; color: var(--ink); border: 1.5px solid var(--border); }
    .btn-o:hover { border-color: var(--ink); transform: translateY(-1px); }
    .hero-stats {
      position: absolute; right: 5vw; bottom: 56px; z-index: 1;
      display: flex; gap: 36px; align-items: center;
    }
    .stat { text-align: center; }
    .stat-n { font-family: var(--font-display); font-size: 2.6rem; color: var(--ink); display: block; line-height: 1; }
    .stat-l { font-size: 0.72rem; color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; display: block; }
    .stat-div { width: 1px; height: 48px; background: var(--border); }

    /* SECTION SKELETON */
    section { padding: 96px 5vw; position: relative; }
    .inner { max-width: 1080px; margin: 0 auto; }
    .s-head { margin-bottom: 56px; }
    .s-eye { font-family: var(--font-mono); font-size: 0.73rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 10px; }
    .s-title { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); color: var(--ink); line-height: 1.1; }
    .s-line { width: 44px; height: 3px; background: var(--accent); margin-top: 14px; border-radius: 2px; }
    .alt { background: var(--cream-dark); }

    /* ABOUT */
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
    .about-text p { color: var(--ink-soft); margin-bottom: 18px; font-size: 1.03rem; line-height: 1.82; }
    .about-text strong { color: var(--ink); }
    .about-cards { display: flex; flex-direction: column; gap: 14px; }
    .acard {
      background: white; border: 1px solid var(--border); border-radius: 10px;
      padding: 18px 22px; display: flex; align-items: flex-start; gap: 14px;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .acard:hover { box-shadow: 0 8px 32px var(--shadow); transform: translateY(-2px); }
    .acard-icon { width: 40px; height: 40px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
    .ic-o { background: var(--accent-light); }
    .ic-b { background: var(--accent2-light); }
    .ic-g { background: var(--green-light); }
    .acard h4 { font-size: 0.88rem; font-weight: 600; color: var(--ink); margin-bottom: 3px; }
    .acard p { font-size: 0.8rem; color: var(--ink-muted); margin: 0; }

    /* SKILLS */
    .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 18px; }
    .sgroup {
      background: white; border: 1px solid var(--border); border-radius: 12px;
      padding: 22px; transition: box-shadow 0.2s;
    }
    .sgroup:hover { box-shadow: 0 8px 28px var(--shadow); }
    .sgroup-label {
      font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--ink-muted);
      margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid var(--border);
    }
    .spills { display: flex; flex-wrap: wrap; gap: 7px; }
    .spill {
      font-size: 0.76rem; font-weight: 500; padding: 4px 12px; border-radius: 20px;
      background: var(--cream); border: 1px solid var(--border); color: var(--ink-soft);
    }
    .spill.hot { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }

    /* CERTS */
    .cert-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(195px, 1fr)); gap: 14px; }
    .ccard {
      background: white; border: 1px solid var(--border); border-radius: 10px;
      padding: 16px 18px; display: flex; align-items: center; gap: 12px;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .ccard:hover { box-shadow: 0 6px 22px var(--shadow); transform: translateY(-2px); }
    .cbadge {
      width: 36px; height: 36px; border-radius: 8px; background: var(--accent-light);
      display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0;
    }
    .cname { font-size: 0.8rem; font-weight: 600; color: var(--ink); line-height: 1.3; }
    .ctype { font-size: 0.7rem; color: var(--ink-muted); margin-top: 2px; }

    /* EXPERIENCE */
    .timeline { position: relative; }
    .timeline::before { content: ''; position: absolute; left: 0; top: 8px; bottom: 0; width: 1px; background: var(--border); }
    .titem { padding-left: 34px; padding-bottom: 50px; position: relative; }
    .titem:last-child { padding-bottom: 0; }
    .tdot {
      position: absolute; left: -7px; top: 8px;
      width: 15px; height: 15px; border-radius: 50%;
      background: var(--accent); border: 3px solid var(--cream);
    }
    .tmeta { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin-bottom: 6px; }
    .trole { font-family: var(--font-display); font-size: 1.22rem; color: var(--ink); }
    .tco { font-size: 0.85rem; color: var(--accent); font-weight: 500; }
    .tperiod { font-family: var(--font-mono); font-size: 0.73rem; color: var(--ink-muted); margin-left: auto; }
    .tbullets { margin-top: 16px; display: flex; flex-direction: column; gap: 10px; }
    .tbullet { display: flex; gap: 12px; font-size: 0.88rem; color: var(--ink-soft); line-height: 1.65; }
    .tbullet::before { content: '→'; color: var(--accent); flex-shrink: 0; margin-top: 1px; }
    .tbullet strong { color: var(--ink); }
    .thighlights { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
    .thl { font-family: var(--font-mono); font-size: 0.73rem; font-weight: 500; padding: 5px 14px; border-radius: 4px; background: var(--cream); border: 1px solid var(--border); color: var(--ink); }
    .thl.a { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }

    /* PROJECTS */
    .pgrid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 22px; }
    .pcard {
      background: white; border: 1px solid var(--border); border-radius: 14px;
      padding: 26px; display: flex; flex-direction: column;
      transition: box-shadow 0.25s, transform 0.25s; position: relative; overflow: hidden;
    }
    .pcard::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; }
    .pcard.po::before { background: var(--accent); }
    .pcard.pb::before { background: var(--accent2); }
    .pcard.pg::before { background: var(--green); }
    .pcard:hover { box-shadow: 0 16px 48px var(--shadow); transform: translateY(-4px); }
    .picon { font-size: 26px; margin-bottom: 12px; }
    .ptitle { font-family: var(--font-display); font-size: 1.15rem; color: var(--ink); margin-bottom: 10px; }
    .pdesc { font-size: 0.86rem; color: var(--ink-soft); line-height: 1.72; flex: 1; margin-bottom: 20px; }
    .ptech { display: flex; flex-wrap: wrap; gap: 7px; }
    .ptag { font-family: var(--font-mono); font-size: 0.68rem; padding: 3px 10px; border-radius: 3px; background: var(--cream-dark); color: var(--ink-soft); border: 1px solid var(--border); }

    /* EDUCATION */
    .egrid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
    .ecard {
      background: white; border: 1px solid var(--border); border-radius: 12px;
      padding: 28px; transition: box-shadow 0.2s, transform 0.2s;
    }
    .ecard:hover { box-shadow: 0 8px 32px var(--shadow); transform: translateY(-2px); }
    .edeg { font-family: var(--font-display); font-size: 1.18rem; color: var(--ink); margin-bottom: 6px; }
    .eschool { font-size: 0.88rem; color: var(--accent); font-weight: 500; margin-bottom: 4px; }
    .eyear { font-family: var(--font-mono); font-size: 0.73rem; color: var(--ink-muted); margin-bottom: 14px; }
    .edetail { font-size: 0.84rem; color: var(--ink-soft); line-height: 1.7; }
    .ebadge {
      display: inline-block; margin-top: 16px; font-family: var(--font-mono); font-size: 0.7rem;
      padding: 4px 12px; border-radius: 20px; background: var(--gold-light); border: 1px solid var(--gold); color: var(--gold);
    }

    /* CONTACT */
    .cwrap { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
    .cinfo h3 { font-family: var(--font-display); font-size: 1.75rem; color: var(--ink); margin-bottom: 14px; }
    .cinfo > p { color: var(--ink-soft); line-height: 1.8; margin-bottom: 28px; }
    .clinks { display: flex; flex-direction: column; gap: 14px; }
    .clink {
      display: flex; align-items: center; gap: 14px;
      text-decoration: none; color: var(--ink); padding: 14px 18px;
      border-radius: 10px; border: 1px solid var(--border); background: white;
      transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    }
    .clink:hover { box-shadow: 0 6px 24px var(--shadow); transform: translateY(-2px); border-color: var(--accent); }
    .clink-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
    .clink strong { display: block; font-size: 0.84rem; color: var(--ink); font-weight: 600; }
    .clink span { font-size: 0.76rem; color: var(--ink-muted); }
    .ccta { background: var(--cream); border-radius: 12px; padding: 34px; border: 1px solid var(--border); }
    .ccta h4 { font-family: var(--font-display); font-size: 1.35rem; color: var(--ink); margin-bottom: 10px; }
    .ccta p { font-size: 0.86rem; color: var(--ink-soft); margin-bottom: 22px; line-height: 1.7; }
    .rbtns { display: flex; flex-direction: column; gap: 12px; }

    /* FOOTER */
    footer {
      background: var(--ink); color: var(--cream);
      padding: 38px 5vw; display: flex; align-items: center;
      justify-content: space-between; flex-wrap: wrap; gap: 14px;
    }
    .fname { font-family: var(--font-display); font-size: 1.15rem; }
    .fcopy { font-size: 0.78rem; color: var(--ink-muted); }

    /* ANIMATIONS */
    .fu { opacity: 0; transform: translateY(26px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fu.vis { opacity: 1; transform: translateY(0); }

    /* RESPONSIVE */
    @media (max-width: 760px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
      .nav-links.open {
        display: flex; flex-direction: column;
        position: absolute; top: 62px; left: 0; right: 0;
        background: rgba(250,247,242,0.97);
        backdrop-filter: blur(14px);
        padding: 20px 5vw; border-bottom: 1px solid var(--border); gap: 16px;
      }
      .hero { min-height: auto; padding-bottom: 140px; }
      .hero-stats { gap: 18px; }
      .stat-n { font-size: 1.9rem; }
      .about-grid, .egrid, .cwrap { grid-template-columns: 1fr; gap: 28px; }
    }
  </style>
</head>
